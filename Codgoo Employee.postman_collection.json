	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"packages": {},
				"exec": [
					"// Auto-extract token from login response",
					"if (pm.response && pm.response.json && pm.response.json().data && pm.response.json().data.token) {",
					"    pm.collectionVariables.set('token', pm.response.json().data.token);",
					"    console.log('Token extracted and saved:', pm.response.json().data.token);",
					"}"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"packages": {},
				"exec": [
					"// Auto-extract token from login response",
					"if (pm.response && pm.response.json && pm.response.json().data && pm.response.json().data.token) {",
					"    pm.collectionVariables.set('token', pm.response.json().data.token);",
					"    console.log('Token extracted and saved:', pm.response.json().data.token);",
					"}",
					"",
					"// Basic response validation",
					"pm.test('Status code is successful', function () {",
					"    pm.expect(pm.response.code).to.be.oneOf([200, 201, 202]);",
					"});",
					"",
					"pm.test('Response has JSON body', function () {",
					"    pm.response.to.have.jsonBody();",
					"});",
					"",
					"pm.test('Response has status field', function () {",
					"    pm.expect(pm.response.json()).to.have.property('status');",
					"});"
				]
			}
		}
